L10N="-* ca ca-ES es es-ES eo ja ja_JP"

ACCEPT_LICENSE="*"
ACCEPT_KEYWORDS="~amd64"

CPU_FLAGS_X86="aes avx f16c mmx mmxext popcnt sse sse2 sse3 sse4_1 sse4_2 ssse3"

# we need -flexiblas as a workaround for numpy sigsev
USE="btrfs lm-sensors vaapi pgo zsh-completion -flexiblas"

RUBY_TARGETS="-* ruby34 ruby40"
